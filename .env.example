# MySQL Performance Schema Monitor Configuration
# Copy this file to .env and configure your databases

# ========================================
# Development Database
# ========================================
DEV_MYSQL_HOST=localhost
DEV_MYSQL_PORT=3306
DEV_MYSQL_USER=your_username
DEV_MYSQL_PASSWORD=your_password
DEV_MONITOR_INTERVAL=10    # 检查间隔（秒）
DEV_MONITOR_THRESHOLD=10   # 慢查询阈值（秒）

# 钉钉通知（可选）
DEV_DINGTALK_WEBHOOK=
DEV_DINGTALK_SECRET=

# 邮件通知（可选）
DEV_EMAIL_ENABLED=false
DEV_EMAIL_FROM=
DEV_EMAIL_TO=
DEV_EMAIL_SMTP_HOST=
DEV_EMAIL_SMTP_PORT=587
DEV_EMAIL_USERNAME=
DEV_EMAIL_PASSWORD=

# 通知间隔（秒），避免告警风暴
DEV_NOTIFY_INTERVAL=300

# ========================================
# Test Database
# ========================================
TEST_MYSQL_HOST=localhost
TEST_MYSQL_PORT=3306
TEST_MYSQL_USER=your_username
TEST_MYSQL_PASSWORD=your_password
TEST_MONITOR_INTERVAL=10
TEST_MONITOR_THRESHOLD=10

# 钉钉通知（可选）
TEST_DINGTALK_WEBHOOK=
TEST_DINGTALK_SECRET=

# 邮件通知（可选）
TEST_EMAIL_ENABLED=false
TEST_EMAIL_FROM=
TEST_EMAIL_TO=
TEST_EMAIL_SMTP_HOST=
TEST_EMAIL_SMTP_PORT=587
TEST_EMAIL_USERNAME=
TEST_EMAIL_PASSWORD=

# 通知间隔（秒）
TEST_NOTIFY_INTERVAL=300

# ========================================
# Production Database
# ========================================
PROD_MYSQL_HOST=your_mysql_host
PROD_MYSQL_PORT=3306
PROD_MYSQL_USER=your_username
PROD_MYSQL_PASSWORD=your_password
PROD_MONITOR_INTERVAL=10
PROD_MONITOR_THRESHOLD=10

# 钉钉通知（必填，生产环境强烈建议配置）
PROD_DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN
PROD_DINGTALK_SECRET=

# 邮件通知（可选）
PROD_EMAIL_ENABLED=false
PROD_EMAIL_FROM=monitor@example.com
PROD_EMAIL_TO=admin@example.com,ops@example.com
PROD_EMAIL_SMTP_HOST=smtp.example.com
PROD_EMAIL_SMTP_PORT=587
PROD_EMAIL_USERNAME=monitor@example.com
PROD_EMAIL_PASSWORD=your-email-password

# 通知间隔（秒），避免频繁告警
PROD_NOTIFY_INTERVAL=300

# ========================================
# Custom Database (Optional)
# ========================================
# Uncomment and configure if you need additional monitoring
# CUSTOM_MYSQL_HOST=your-host
# CUSTOM_MYSQL_PORT=3306
# CUSTOM_MYSQL_USER=your-user
# CUSTOM_MYSQL_PASSWORD=your-password
# CUSTOM_MONITOR_INTERVAL=10
# CUSTOM_MONITOR_THRESHOLD=10

# ========================================
# Notes
# ========================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual credentials
# 3. Add .env to .gitignore to avoid committing secrets
# 4. Start monitoring: make up-prod
# 5. View logs: make logs-prod
