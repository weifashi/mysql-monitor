# MySQL Monitor Web 管理配置
# 复制此文件为 .env 并修改

# 管理员账号（必填）
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Web 端口（可选，默认 8080）
# WEB_PORT=8080

# Docker / 反代后 GitHub OAuth：与浏览器地址栏一致的根 URL（无末尾 /），须与 GitHub OAuth App 回调前缀一致
# PUBLIC_BASE_URL=https://your-host.example.com

# 可选：首次启动写入数据库并启用 GitHub 登录
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
